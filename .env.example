# Project Configuration
PROJECT_NAME="Personal Expense Tracker API"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# Security & JWT Configuration
# IMPORTANT: Change SECRET_KEY in production!
SECRET_KEY="super-secret-jwt-key-change-this-in-production-use-openssl-rand-hex-32"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# PostgreSQL Database Configuration
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=expense_user
POSTGRES_PASSWORD=expense_password
POSTGRES_DB=expense_tracker_db
DATABASE_URL=postgresql://expense_user:expense_password@db:5432/expense_tracker_db

# MinIO Object Storage Configuration
MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=expense-bills
MINIO_SECURE=false

# CORS Configuration (JSON-encoded array string or comma-separated)
BACKEND_CORS_ORIGINS=["http://localhost", "http://localhost:8000", "http://localhost:3000"]
